import csv
import datetime
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# STUDENT CLASS
class Student:
    def __init__(self, student_id, name, dept):
        self.student_id = student_id
        self.name = name
        self.dept = dept


# QUIZ CLASS
class Quiz:
    def __init__(self):
        self.questions = [
            "1. Python is a ___ language?\nA) Low-level\nB) High-level\nC) Machine\nD) Assembly",
            "2. Which is used for data analysis?\nA) NumPy\nB) Pandas\nC) Matplotlib\nD) All",
            "3. Which keyword is used for function?\nA) fun\nB) define\nC) def\nD) function"
        ]
        self.answers = ['B', 'D', 'C']


# RESULT CLASS
class Result:
    def __init__(self, student_id, score, percentage):
        self.student_id = student_id
        self.score = score
        self.percentage = percentage
        self.timestamp = datetime.datetime.now()


# MAIN SYSTEM
class QAPAS:
    def __init__(self):
        self.students = {}
        self.quiz = Quiz()
        self.results_file = "results.csv"

    # STUDENT REGISTRATION
    def register_student(self):
        student_id = input("Enter Student ID: ")
        
        if student_id in self.students:
            print("Student already exists!")
            return

        name = input("Enter Name: ")
        dept = input("Enter Department: ")
        self.students[student_id] = Student(student_id, name, dept)
        print("Student Registered Successfully!\n")

    # QUIZ
    def attempt_quiz(self):
        student_id = input("Enter Student ID: ")
        
        if student_id not in self.students:
            print("Student not found!")
            return

        score = 0

        for i, q in enumerate(self.quiz.questions):
            print(q)
            ans = input("Enter answer: ").upper()

            if ans == self.quiz.answers[i]:
                score += 1

        percentage = (score / len(self.quiz.questions)) * 100

        print(f"\nScore: {score}")
        print(f"Percentage: {percentage:.2f}%")

        self.save_result(Result(student_id, score, percentage))

    # SAVE RESULT
    def save_result(self, result):
        file_exists = False
        
        try:
            with open(self.results_file, 'r'):
                file_exists = True
        except FileNotFoundError:
            file_exists = False

        with open(self.results_file, 'a', newline='') as file:
            writer = csv.writer(file)

            if not file_exists:
                writer.writerow(["Student_ID", "Score", "Percentage", "Timestamp"])

            writer.writerow([
                result.student_id,
                result.score,
                result.percentage,
                result.timestamp
            ])

        print("Result Saved Successfully!\n")

    # ANALYTICS
    def analytics(self):
        try:
            df = pd.read_csv(self.results_file)

            print("\n--- Analytics ---")
            print("Average Score:", np.mean(df["Score"]))
            print("Highest Score:", np.max(df["Score"]))
            print("Lowest Score:", np.min(df["Score"]))

            # Bar Chart
            df.groupby("Student_ID")["Score"].mean().plot(kind='bar')
            plt.title("Student-wise Performance")
            plt.xlabel("Student ID")
            plt.ylabel("Average Score")
            plt.show()

            # Pie Chart
            pass_count = (df["Percentage"] >= 40).sum()
            fail_count = (df["Percentage"] < 40).sum()

            plt.pie([pass_count, fail_count],
                    labels=["Pass", "Fail"],
                    autopct='%1.1f%%')
            plt.title("Pass/Fail Distribution")
            plt.show()

        except Exception as e:
            print("Error in analytics:", e)

    # MENU
    def menu(self):
        while True:
            print("\n--- QAPAS MENU ---")
            print("1. Register Student")
            print("2. Attempt Quiz")
            print("3. View Analytics")
            print("4. Exit")

            choice = input("Enter choice: ")

            if choice == '1':
                self.register_student()
            elif choice == '2':
                self.attempt_quiz()
            elif choice == '3':
                self.analytics()
            elif choice == '4':
                print("Exiting...")
                break
            else:
                print("Invalid choice!")


# RUN PROGRAM
if __name__ == "__main__":
    system = QAPAS()
    system.menu()
